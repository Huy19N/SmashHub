{
    "rewrites": [
        {
            "source": "/api/:path*",
            "destination": "http://tad-min.io.vn:5000/api/:path*"
        },
        {
            "source": "/hub/:path*",
            "destination": "http://tad-min.io.vn:5000/hub/:path*"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}